---
import { Icon } from 'astro-icon/components';
import type { System } from '~/data/inquiry-types';

export interface Props {
  system: System;
}

const { system } = Astro.props;

const colorMap: Record<string, { icon: string; text: string; hoverBg: string; border: string }> = {
  blue: {
    icon: 'text-teal-500',
    text: 'text-teal-500',
    hoverBg: 'hover:bg-slate-50 dark:hover:bg-slate-800/50',
    border: 'group-hover:border-teal-500',
  },
  emerald: {
    icon: 'text-emerald-500',
    text: 'text-emerald-500',
    hoverBg: 'hover:bg-slate-50 dark:hover:bg-slate-800/50',
    border: 'group-hover:border-emerald-500',
  },
  cyan: {
    icon: 'text-cyan-500',
    text: 'text-cyan-500',
    hoverBg: 'hover:bg-slate-50 dark:hover:bg-slate-800/50',
    border: 'group-hover:border-cyan-500',
  },
  amber: {
    icon: 'text-amber-500',
    text: 'text-amber-500',
    hoverBg: 'hover:bg-slate-50 dark:hover:bg-slate-800/50',
    border: 'group-hover:border-amber-500',
  },
  slate: {
    icon: 'text-slate-600',
    text: 'text-slate-600',
    hoverBg: 'hover:bg-slate-50 dark:hover:bg-slate-800/50',
    border: 'group-hover:border-slate-600',
  },
  stone: {
    icon: 'text-stone-600',
    text: 'text-stone-600',
    hoverBg: 'hover:bg-slate-50 dark:hover:bg-slate-800/50',
    border: 'group-hover:border-stone-600',
  },
  violet: {
    icon: 'text-violet-500',
    text: 'text-violet-500',
    hoverBg: 'hover:bg-slate-50 dark:hover:bg-slate-800/50',
    border: 'group-hover:border-violet-500',
  },
};

const colors = colorMap[system.color] || colorMap.blue;
---

<a
  href={`/${system.slug}`}
  class={`group block rounded-xl border border-gray-200 bg-white p-5 transition-all duration-300 ${colors.hoverBg} ${colors.border} dark:border-slate-700 dark:bg-slate-900/50`}
>
  <div class="flex items-start justify-between">
    <Icon
      name={system.icon}
      class={`h-5 w-5 ${colors.icon}`}
    />
    <span class={`tech-label text-slate-400 ${colors.text}`}>
      {String(system.areas.length).padStart(2, '0')}
    </span>
  </div>

  <h3
    class="mt-4 text-base font-semibold text-gray-900 dark:text-white"
    style="font-family: 'Space Grotesk Variable', sans-serif; letter-spacing: -0.02em;"
  >
    {system.name}
  </h3>

  <p class="mt-1.5 text-sm text-muted leading-relaxed line-clamp-2">
    {system.shortDesc}
  </p>

  <div class="mt-4 flex items-center justify-between border-t border-gray-100 pt-3 dark:border-slate-700/50">
    <span class="tech-label text-slate-400">Categories</span>
    <span class={`inline-flex items-center gap-1 text-sm font-medium ${colors.text} transition-transform duration-300 group-hover:translate-x-0.5`}>
      <Icon name="tabler:arrow-right" class="h-3.5 w-3.5" />
    </span>
  </div>
</a>
