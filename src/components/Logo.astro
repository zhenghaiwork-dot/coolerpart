---
import { SITE } from 'astrowind:config';
---

<span class="self-center ml-2 rtl:ml-0 rtl:mr-2 flex items-center gap-2.5 whitespace-nowrap">
  <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 shrink-0" viewBox="0 0 128 128" fill="none" aria-hidden="true">
    <path d="M64 12C64 12 28 56 28 82C28 102 44 116 64 116C84 116 100 102 100 82C100 56 64 12 64 12Z"
          fill="none" stroke="#0d9488" stroke-width="5" stroke-linejoin="round"/>
    <g transform="translate(64,78)">
      <circle r="18" class="gear-body"/>
      <rect x="-3.5" y="-25" width="7" height="10" rx="1.5" class="gear-tooth"/>
      <rect x="-3.5" y="-25" width="7" height="10" rx="1.5" class="gear-tooth" transform="rotate(45)"/>
      <rect x="-3.5" y="-25" width="7" height="10" rx="1.5" class="gear-tooth" transform="rotate(90)"/>
      <rect x="-3.5" y="-25" width="7" height="10" rx="1.5" class="gear-tooth" transform="rotate(135)"/>
      <rect x="-3.5" y="-25" width="7" height="10" rx="1.5" class="gear-tooth" transform="rotate(180)"/>
      <rect x="-3.5" y="-25" width="7" height="10" rx="1.5" class="gear-tooth" transform="rotate(225)"/>
      <rect x="-3.5" y="-25" width="7" height="10" rx="1.5" class="gear-tooth" transform="rotate(270)"/>
      <rect x="-3.5" y="-25" width="7" height="10" rx="1.5" class="gear-tooth" transform="rotate(315)"/>
      <circle r="7" class="gear-center"/>
    </g>
    <style>
      .gear-body, .gear-tooth { fill: #0f172a; }
      .gear-center { fill: #fff; }
      @media (prefers-color-scheme: dark) {
        .gear-body, .gear-tooth { fill: #e2e8f0; }
        .gear-center { fill: #0f172a; }
      }
    </style>
  </svg>
  <span class="text-lg md:text-base font-bold text-gray-900 dark:text-white tracking-tight" style="font-family: 'Space Grotesk Variable', sans-serif; letter-spacing: -0.02em;">
    {SITE?.name}
  </span>
</span>
