---
import { SITE } from 'astrowind:config';
---

<span class="self-center ml-2 rtl:ml-0 rtl:mr-2 flex items-center gap-2.5 whitespace-nowrap">
  <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 shrink-0" viewBox="0 0 64 64" aria-hidden="true">
    <rect x="2" y="2" width="60" height="60" rx="14" fill="#0d9488"/>
    <g fill="#fff">
      <circle cx="32" cy="32" r="12"/>
      <rect x="28.5" y="12" width="7" height="10" rx="2"/>
      <rect x="28.5" y="12" width="7" height="10" rx="2" transform="rotate(60,32,32)"/>
      <rect x="28.5" y="12" width="7" height="10" rx="2" transform="rotate(120,32,32)"/>
      <rect x="28.5" y="12" width="7" height="10" rx="2" transform="rotate(180,32,32)"/>
      <rect x="28.5" y="12" width="7" height="10" rx="2" transform="rotate(240,32,32)"/>
      <rect x="28.5" y="12" width="7" height="10" rx="2" transform="rotate(300,32,32)"/>
    </g>
    <circle cx="32" cy="32" r="5" fill="#0d9488"/>
    <path d="M50 44C50 44 44 50 44 53C44 56 46.5 58 50 58C53.5 58 56 56 56 53C56 50 50 44 50 44Z" fill="#fff" opacity="0.85"/>
  </svg>
  <span class="text-lg md:text-base font-bold text-gray-900 dark:text-white tracking-tight" style="font-family: 'Space Grotesk Variable', sans-serif; letter-spacing: -0.02em;">
    {SITE?.name}
  </span>
</span>
