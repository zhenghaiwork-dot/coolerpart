---
import Layout from '~/layouts/InquiryLayout.astro';
import { getAllProducts } from '~/data/product-helpers';
const allProducts = await getAllProducts();
const motors = allProducts.filter(p => p.systemSlug === 'electrical-controls' && (p.areaSlug === 'motors-drive' || p.areaSlug === 'control-board-protection'));
---
<Layout metadata={{ title: 'Replacement Motors for Evaporative Coolers | B3 B5 Mount', ignoreTitleTemplate: true }}>
  <section class="overflow-hidden bg-gradient-to-br from-slate-900 via-teal-900 to-slate-900 text-white">
    <div class="mx-auto max-w-3xl px-4 py-16 text-center sm:px-6 sm:py-20">
      <h1 class="text-3xl font-extrabold tracking-tight sm:text-4xl">Replacement Motors</h1>
      <p class="mt-4 text-lg text-gray-300">Compatible replacement motors for evaporative coolers. Match by voltage, power, RPM, and mounting type — no model number needed.</p>
      <div class="mt-6 flex justify-center gap-3"><a href="/electrical-controls/motors-drive" class="rounded-xl bg-teal-600 px-6 py-3 text-sm font-semibold text-white hover:bg-teal-700">Browse All Motors</a><a href="/inquiry" class="rounded-xl border border-gray-500 px-6 py-3 text-sm font-semibold text-white hover:bg-white/10">Request Quote</a></div>
    </div>
  </section>
  <section class="bg-white dark:bg-slate-900">
    <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 sm:py-16">
      <div class="mb-8 flex flex-wrap gap-3"><span class="rounded-full bg-teal-50 px-3 py-1 text-xs font-medium text-teal-700 dark:bg-teal-900/20 dark:text-teal-400">Filter by voltage, power or RPM in our catalog</span></div>
      <h2 class="mb-8 text-2xl font-bold">Available Motors & Electrical Parts ({motors.length})</h2>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {motors.map(p => (
          <a href={`/${p.systemSlug}/${p.areaSlug}/${p.productTypeSlug}/${p.slug}`} class="group rounded-xl border p-5 hover:shadow-md transition-all dark:border-slate-700">
            <h3 class="font-semibold text-gray-900 group-hover:text-teal-600 dark:text-white">{p.name}</h3>
            <p class="mt-1 text-sm text-muted line-clamp-2">{p.description}</p>
            <div class="mt-2 flex flex-wrap gap-1">{p.specs.slice(0,4).map(s=><span class="rounded bg-gray-100 px-2 py-0.5 text-xs text-muted dark:bg-slate-700">{s.value}</span>)}</div>
            <span class="mt-3 inline-block text-xs text-teal-600">{p.moq} &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
