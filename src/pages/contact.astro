---
import Layout from '~/layouts/InquiryLayout.astro';
import { Icon } from 'astro-icon/components';
---
<Layout metadata={{ title: 'Contact Us — EVAPFit', ignoreTitleTemplate: true }}>
  <section class="overflow-hidden bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white">
    <div class="mx-auto max-w-3xl px-4 py-16 text-center sm:px-6 sm:py-20">
      <h1 class="text-3xl font-extrabold tracking-tight sm:text-4xl">Contact Us</h1>
      <p class="mt-4 text-lg text-gray-300">We respond within 24 hours.</p>
    </div>
  </section>
  <section class="bg-white dark:bg-slate-900">
    <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6 sm:py-16">
      <div class="grid gap-8 lg:grid-cols-3 mb-12">
        <div class="rounded-xl border p-6 text-center dark:border-slate-700"><Icon name="tabler:mail" class="mx-auto h-8 w-8 text-teal-600 mb-3"/><h3 class="font-semibold">Email</h3><p class="text-sm text-muted mt-1">rfq@aircoolerparts.com</p></div>
        <div class="rounded-xl border p-6 text-center dark:border-slate-700"><Icon name="tabler:phone" class="mx-auto h-8 w-8 text-teal-600 mb-3"/><h3 class="font-semibold">Phone / WhatsApp</h3><p class="text-sm text-muted mt-1">+86 138 0000 0000</p></div>
        <div class="rounded-xl border p-6 text-center dark:border-slate-700"><Icon name="tabler:map-pin" class="mx-auto h-8 w-8 text-teal-600 mb-3"/><h3 class="font-semibold">Address</h3><p class="text-sm text-muted mt-1">Ningbo, Zhejiang, China</p></div>
      </div>
      <div class="max-w-lg mx-auto text-center">
        <h2 class="text-xl font-bold mb-4">Get a Quote</h2>
        <p class="text-sm text-muted mb-6">Use our inquiry form with pre-filled product details for the fastest response.</p>
        <a href="/inquiry" class="inline-flex items-center gap-2 rounded-xl bg-teal-600 px-8 py-3.5 text-base font-semibold text-white hover:bg-teal-700"><Icon name="tabler:mail" class="h-5 w-5"/> Request a Quote</a>
      </div>
    </div>
  </section>
</Layout>
