---
import Layout from '~/layouts/InquiryLayout.astro';
import { productsData } from '~/data/products';
const pumps = productsData.filter(p => p.systemSlug === 'water-system' && p.areaSlug === 'water-pump-power');
---
<Layout metadata={{ title: 'Water Pump Replacement Parts for Evaporative Coolers | Compatible by Interface', ignoreTitleTemplate: true }}>
  <section class="overflow-hidden bg-gradient-to-br from-slate-900 via-teal-900 to-slate-900 text-white">
    <div class="mx-auto max-w-3xl px-4 py-16 text-center sm:px-6 sm:py-20">
      <h1 class="text-3xl font-extrabold tracking-tight sm:text-4xl">Water Pump Replacement Parts</h1>
      <p class="mt-4 text-lg text-gray-300">Find compatible replacement water pumps and accessories for portable and cabinet evaporative air coolers. Threaded, push-fit, and hose barb connections available.</p>
      <div class="mt-6 flex justify-center gap-3"><a href="/water-system/water-pump-power" class="rounded-xl bg-teal-600 px-6 py-3 text-sm font-semibold text-white hover:bg-teal-700">Browse All Pumps</a><a href="/inquiry" class="rounded-xl border border-gray-500 px-6 py-3 text-sm font-semibold text-white hover:bg-white/10">Request Quote</a></div>
    </div>
  </section>
  <section class="bg-white dark:bg-slate-900">
    <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 sm:py-16">
      <h2 class="mb-8 text-2xl font-bold">Available Water Pump Parts ({pumps.length})</h2>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {pumps.map(p => (
          <a href={`/${p.systemSlug}/${p.areaSlug}/${p.productTypeSlug}/${p.slug}`} class="group rounded-xl border p-5 hover:shadow-md transition-all dark:border-slate-700">
            <h3 class="font-semibold text-gray-900 group-hover:text-teal-600 dark:text-white">{p.name}</h3>
            <p class="mt-1 text-sm text-muted line-clamp-2">{p.description}</p>
            <div class="mt-2 flex flex-wrap gap-1">{p.specs.slice(0,3).map(s=><span class="rounded bg-gray-100 px-2 py-0.5 text-xs text-muted dark:bg-slate-700">{s.value}</span>)}</div>
            <span class="mt-3 inline-block text-xs text-teal-600">{p.moq} &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
