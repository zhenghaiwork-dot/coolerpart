---
import Layout from '~/layouts/InquiryLayout.astro';
import { Icon } from 'astro-icon/components';
import { systemsData } from '~/data/systems';
import { getAllProducts } from '~/data/product-helpers';

const productsData = await getAllProducts();

const metadata = {
  title: 'Evaporative Air Cooler Parts & Replacement Components | EVAPFit',
  description: 'Source compatible evaporative air cooler parts and replacement components: water pumps, motors, cooling pads, valves, controls and mounting hardware. Match by specifications and request a bulk RFQ.',
  ignoreTitleTemplate: true,
};

const totalParts = productsData.length;
const totalTypes = new Set(productsData.map((p) => p.productTypeSlug)).size;
const totalSystems = systemsData.length;

// Popular parts — 8 representative items
const popularParts = productsData.slice(0, 8);

// Get specific parts for the system cards preview
const waterSystem = systemsData.find((s) => s.slug === 'water-system')!;
const electricalSystem = systemsData.find((s) => s.slug === 'electrical-controls')!;
const waterPartCount = productsData.filter((p) => p.systemSlug === 'water-system').length;
const electricalPartCount = productsData.filter((p) => p.systemSlug === 'electrical-controls').length;

// Quick match — 2 system shortcuts
const quickMatchSystems = [
  { slug: 'water-system', name: 'Water System', icon: 'tabler:droplet', desc: 'Pumps, valves, filtration' },
  { slug: 'electrical-controls', name: 'Electrical & Controls', icon: 'tabler:bolt', desc: 'Motors, capacitors, control boards' },
];

// Filter categories for fast narrowing
const filterCategories = [
  {
    title: 'Voltage',
    icon: 'tabler:bolt',
    desc: 'Match electrical input. Hard threshold for motor compatibility.',
    cta: 'Filter by Voltage',
    href: '/compatibility/by-electrical',
  },
  {
    title: 'Power (W)',
    icon: 'tabler:activity',
    desc: 'Match motor output. Critical for replacement motor pairing.',
    cta: 'Filter by Power',
    href: '/compatibility/by-electrical',
  },
  {
    title: 'RPM',
    icon: 'tabler:rotate-clockwise',
    desc: 'Match rotation speed. Direct swap requires identical RPM.',
    cta: 'Filter by RPM',
    href: '/compatibility/by-electrical',
  },
];

// Trust & RFQ trust blocks
const trustBlocks = [
  {
    title: 'Fast RFQ Response',
    desc: 'Submit your inquiry list and receive pricing, availability, and lead time within 24 hours.',
    icon: 'tabler:clock',
  },
  {
    title: 'Exact Fitment Matching',
    desc: 'Interface, dimension, and electrical parameters verified before quoting. OEM-compatible parts.',
    icon: 'tabler:ruler-measure',
  },
  {
    title: 'Global Shipping & Support',
    desc: 'We export to 30+ countries. Flexible incoterms and consolidated shipping for bulk orders.',
    icon: 'tabler:truck-delivery',
  },
];

// Content / guide cards
const contentGuides = [
  {
    title: 'How to Identify Your Part',
    desc: 'Step-by-step guide to identifying the exact replacement based on interface and dimensions.',
    icon: 'tabler:clipboard-list',
    href: '/compatibility',
  },
  {
    title: 'Compatibility Cross-reference',
    desc: 'Match by thread type, flange pattern, or electrical specs — no model number required.',
    icon: 'tabler:arrows-exchange',
    href: '/compatibility',
  },
  {
    title: 'Installation & Specs',
    desc: 'Mounting types, torque specs, and wiring guides for each part category.',
    icon: 'tabler:book',
    href: '/compatibility',
  },
  {
    title: 'RFQ Helper',
    desc: 'What info to include in your inquiry for the fastest possible quote.',
    icon: 'tabler:mail',
    href: '/inquiry',
  },
];

// System slug → short label for popular parts badge
const systemLabelMap: Record<string, string> = {
  'water-system': 'WATER',
  'electrical-controls': 'ELEC',
  'evaporation-system': 'EVAP',
  'air-system': 'AIR',
  'structure-mounting': 'STRUCT',
};
---

<Layout metadata={metadata}>
  <!-- ═══════════════════════════════════════════════
       SECTION 1 — HERO + QUICK MATCH
  ═══════════════════════════════════════════════ -->
  <section class="bg-white dark:bg-slate-900 border-b border-gray-200 dark:border-slate-800">
    <div class="mx-auto max-w-7xl px-6 py-12 lg:py-20">
      <div class="grid gap-10 lg:grid-cols-[1.4fr_1fr] lg:gap-12 items-start">
        <!-- LEFT: Headline + CTAs -->
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-teal-600 dark:text-teal-400">
            Direct Factory Supply
          </p>
          <h1
            class="mt-4 text-4xl font-bold leading-[1.1] text-gray-900 dark:text-white sm:text-5xl lg:text-6xl text-balance"
            style="font-family: 'Space Grotesk Variable', sans-serif; letter-spacing: -0.03em;"
          >
            Evaporative Air Cooler{' '}
            <span class="text-teal-600 dark:text-teal-400">Parts &amp; Replacement Components</span>
          </h1>
          <p class="mt-6 text-lg leading-relaxed text-gray-600 dark:text-gray-300 max-w-xl">
            EVAPFit supplies interface-matched replacement parts for portable and cabinet evaporative air coolers.
            Search by <span class="font-semibold text-gray-900 dark:text-white">system</span>,
            <span class="font-semibold text-gray-900 dark:text-white">electrical specs</span>, or
            <span class="font-semibold text-gray-900 dark:text-white">structure &amp; mounting</span>
            &mdash; no model number required.
          </p>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a
              href="/inquiry"
              class="inline-flex items-center justify-center gap-2 rounded-lg bg-teal-600 px-6 py-3 text-sm font-semibold text-white shadow-sm transition-all hover:bg-teal-700 hover:shadow-md"
            >
              <Icon name="tabler:mail" class="h-4 w-4" />
              Request Quote
            </a>
            <a
              href="#system-entries"
              class="inline-flex items-center justify-center gap-2 rounded-lg border border-gray-300 bg-white px-6 py-3 text-sm font-semibold text-gray-900 transition-all hover:border-teal-500 hover:text-teal-600 dark:border-slate-600 dark:bg-slate-800 dark:text-white dark:hover:border-teal-400 dark:hover:text-teal-400"
            >
              <Icon name="tabler:layout-grid" class="h-4 w-4" />
              Browse Components
            </a>
          </div>

          <!-- Mini stats line -->
          <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-gray-500 dark:text-gray-400">
            <span><span class="font-semibold text-gray-900 dark:text-white tabular-nums">{totalParts}+</span> parts</span>
            <span class="h-3 w-px bg-gray-300 dark:bg-slate-700"></span>
            <span><span class="font-semibold text-gray-900 dark:text-white tabular-nums">{totalTypes}</span> product types</span>
            <span class="h-3 w-px bg-gray-300 dark:bg-slate-700"></span>
            <span><span class="font-semibold text-gray-900 dark:text-white tabular-nums">{totalSystems}</span> systems</span>
            <span class="h-3 w-px bg-gray-300 dark:bg-slate-700"></span>
            <span>30+ countries</span>
          </div>
        </div>

        <!-- RIGHT: Quick match card -->
        <aside class="rounded-xl border border-gray-200 bg-gray-50 p-6 dark:border-slate-700 dark:bg-slate-800/50">
          <div class="flex items-center justify-between">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-gray-500 dark:text-gray-400">
              Quick Match
            </p>
            <Icon name="tabler:bolt" class="h-4 w-4 text-teal-600 dark:text-teal-400" />
          </div>
          <h3
            class="mt-2 text-lg font-semibold text-gray-900 dark:text-white"
            style="font-family: 'Space Grotesk Variable', sans-serif; letter-spacing: -0.02em;"
          >
            Pick a system to start
          </h3>
          <p class="mt-1.5 text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
            Jump to the matching filter page with the right parts pre-loaded.
          </p>

          <div class="mt-5 space-y-2.5">
            {quickMatchSystems.map((sys) => (
              <a
                href={`/${sys.slug}`}
                class="group flex items-center gap-3 rounded-lg border border-gray-200 bg-white px-4 py-3 transition-all hover:border-teal-500 hover:shadow-sm dark:border-slate-700 dark:bg-slate-900/50 dark:hover:border-teal-400"
              >
                <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-teal-50 text-teal-600 transition-colors group-hover:bg-teal-600 group-hover:text-white dark:bg-teal-500/10 dark:text-teal-400 dark:group-hover:bg-teal-500 dark:group-hover:text-white">
                  <Icon name={sys.icon} class="h-4 w-4" />
                </span>
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-semibold text-gray-900 dark:text-white">{sys.name}</p>
                  <p class="text-xs text-gray-500 dark:text-gray-400">{sys.desc}</p>
                </div>
                <Icon name="tabler:arrow-right" class="h-4 w-4 text-gray-400 transition-all group-hover:translate-x-0.5 group-hover:text-teal-600 dark:group-hover:text-teal-400" />
              </a>
            ))}
          </div>

          <div class="mt-5 border-t border-gray-200 pt-4 dark:border-slate-700">
            <p class="text-xs text-gray-500 dark:text-gray-400">
              Or use the
              <a href="#filter-fast" class="font-medium text-teal-600 hover:text-teal-700 dark:text-teal-400 dark:hover:text-teal-300">
                fast filter →
              </a>
              below for Voltage / Power / RPM narrowing.
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 2 — SYSTEM ENTRIES (3 cards: Water + Electrical + Compatibility)
  ═══════════════════════════════════════════════ -->
  <section id="system-entries" class="bg-gray-50 dark:bg-slate-800/30 border-b border-gray-200 dark:border-slate-800">
    <div class="mx-auto max-w-7xl px-6 py-14 lg:py-20">
      <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-gray-500 dark:text-gray-400">
            Browse by System
          </p>
          <h2
            class="mt-2 text-3xl font-bold text-gray-900 dark:text-white sm:text-4xl"
            style="font-family: 'Space Grotesk Variable', sans-serif; letter-spacing: -0.03em;"
          >
            Pick the system you need parts for
          </h2>
        </div>
        <a
          href="/compatibility"
          class="inline-flex items-center gap-1 text-sm font-semibold text-teal-600 hover:text-teal-700 dark:text-teal-400 dark:hover:text-teal-300"
        >
          Or match by compatibility
          <Icon name="tabler:arrow-right" class="h-4 w-4" />
        </a>
      </div>

      <div class="grid gap-5 lg:grid-cols-3">
        <!-- Card 1: Water System -->
        <a
          href={`/${waterSystem.slug}`}
          class="group relative flex flex-col overflow-hidden rounded-xl border border-gray-200 bg-white transition-all hover:border-teal-500 hover:shadow-lg dark:border-slate-700 dark:bg-slate-900 dark:hover:border-teal-400"
        >
          <div class="flex items-center gap-3 border-l-4 border-teal-600 bg-teal-50/50 px-6 py-4 dark:bg-teal-500/5">
            <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-teal-600 text-white">
              <Icon name="tabler:droplet" class="h-4 w-4" />
            </span>
            <div>
              <p class="text-[10px] font-mono font-semibold uppercase tracking-[0.15em] text-teal-600 dark:text-teal-400">
                Mainstream
              </p>
              <p
                class="text-xl font-bold text-gray-900 dark:text-white"
                style="font-family: 'Space Grotesk Variable', sans-serif; letter-spacing: -0.02em;"
              >
                {waterSystem.name}
              </p>
            </div>
          </div>
          <div class="flex-1 p-6">
            <p class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed">
              Pumps, valves, filtration, distribution, tanks & piping — every part for water circulation in evaporative coolers.
            </p>
            <div class="mt-5 flex items-center gap-4 text-xs">
              <span class="font-mono text-gray-500 dark:text-gray-400">
                <span class="font-semibold text-gray-900 dark:text-white tabular-nums">{waterPartCount}</span> parts
              </span>
              <span class="h-3 w-px bg-gray-300 dark:bg-slate-700"></span>
              <span class="font-mono text-gray-500 dark:text-gray-400">
                <span class="font-semibold text-gray-900 dark:text-white tabular-nums">{waterSystem.areas.length}</span> categories
              </span>
            </div>
            <p class="mt-4 text-xs text-gray-500 dark:text-gray-400 leading-relaxed">
              Use cases: portable & cabinet cooler sump circulation, distribution to cooling pads, automated water fill.
            </p>
          </div>
          <div class="flex items-center justify-between border-t border-gray-100 px-6 py-3 dark:border-slate-800">
            <span class="text-sm font-semibold text-teal-600 group-hover:text-teal-700 dark:text-teal-400 dark:group-hover:text-teal-300">
              Explore Components
            </span>
            <Icon name="tabler:arrow-right" class="h-4 w-4 text-teal-600 transition-transform group-hover:translate-x-1 dark:text-teal-400" />
          </div>
        </a>

        <!-- Card 2: Electrical & Controls -->
        <a
          href={`/${electricalSystem.slug}`}
          class="group relative flex flex-col overflow-hidden rounded-xl border border-gray-200 bg-white transition-all hover:border-teal-500 hover:shadow-lg dark:border-slate-700 dark:bg-slate-900 dark:hover:border-teal-400"
        >
          <div class="flex items-center gap-3 border-l-4 border-slate-700 bg-slate-50 px-6 py-4 dark:bg-slate-800/50">
            <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-slate-800 text-teal-400 dark:bg-slate-700">
              <Icon name="tabler:bolt" class="h-4 w-4" />
            </span>
            <div>
              <p class="text-[10px] font-mono font-semibold uppercase tracking-[0.15em] text-slate-500 dark:text-slate-400">
                Mainstream
              </p>
              <p
                class="text-xl font-bold text-gray-900 dark:text-white"
                style="font-family: 'Space Grotesk Variable', sans-serif; letter-spacing: -0.02em;"
              >
                {electricalSystem.name}
              </p>
            </div>
          </div>
          <div class="flex-1 p-6">
            <p class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed">
              Motors, capacitors, control boards, contactors, sensors, and wiring harnesses for cooler electronics.
            </p>
            <div class="mt-5 flex items-center gap-4 text-xs">
              <span class="font-mono text-gray-500 dark:text-gray-400">
                <span class="font-semibold text-gray-900 dark:text-white tabular-nums">{electricalPartCount}</span> parts
              </span>
              <span class="h-3 w-px bg-gray-300 dark:bg-slate-700"></span>
              <span class="font-mono text-gray-500 dark:text-gray-400">
                <span class="font-semibold text-gray-900 dark:text-white tabular-nums">{electricalSystem.areas.length}</span> categories
              </span>
            </div>
            <p class="mt-4 text-xs text-gray-500 dark:text-gray-400 leading-relaxed">
              Use cases: motor replacement, speed control, automated fill/overflow protection, PCB swap.
            </p>
          </div>
          <div class="flex items-center justify-between border-t border-gray-100 px-6 py-3 dark:border-slate-800">
            <span class="text-sm font-semibold text-teal-600 group-hover:text-teal-700 dark:text-teal-400 dark:group-hover:text-teal-300">
              Explore Components
            </span>
            <Icon name="tabler:arrow-right" class="h-4 w-4 text-teal-600 transition-transform group-hover:translate-x-1 dark:text-teal-400" />
          </div>
        </a>

        <!-- Card 3: Compatibility — Full Image -->
        <a
          href="/compatibility"
          class="group relative overflow-hidden rounded-xl border border-gray-200 bg-white transition-all hover:border-teal-500 hover:shadow-lg dark:border-slate-700 dark:bg-slate-900 dark:hover:border-teal-400"
        >
          <img
            src="https://cdn.aircoolerparts.com/gallery/swamp-cooler-spare-parts.webp"
            alt="Evaporative Cooler Spare Parts — Compatibility Guide"
            class="w-full h-auto object-cover"
            loading="lazy"
          />
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 3 — FAST FILTER (Voltage / Power / RPM)
  ═══════════════════════════════════════════════ -->
  <section id="filter-fast" class="bg-white dark:bg-slate-900 border-b border-gray-200 dark:border-slate-800">
    <div class="mx-auto max-w-7xl px-6 py-14 lg:py-20">
      <div class="mb-8 max-w-2xl">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-gray-500 dark:text-gray-400">
          Find the Right Component Fast
        </p>
        <h2
          class="mt-2 text-3xl font-bold text-gray-900 dark:text-white sm:text-4xl"
          style="font-family: 'Space Grotesk Variable', sans-serif; letter-spacing: -0.03em;"
        >
          Narrow by electrical hard-matches
        </h2>
        <p class="mt-3 text-base text-gray-600 dark:text-gray-300 leading-relaxed">
          Three hard thresholds that determine if a motor or control part will physically work in your cooler.
        </p>
      </div>

      <div class="grid gap-4 md:grid-cols-3">
        {filterCategories.map((f, i) => (
          <a
            href={f.href}
            class="group relative flex flex-col rounded-xl border border-gray-200 bg-white p-6 transition-all hover:border-teal-500 hover:shadow-md dark:border-slate-700 dark:bg-slate-800/50 dark:hover:border-teal-400"
          >
            <div class="flex items-start justify-between">
              <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-teal-50 text-teal-600 dark:bg-teal-500/10 dark:text-teal-400">
                <Icon name={f.icon} class="h-4 w-4" />
              </span>
              <span class="font-mono text-xs text-gray-400 dark:text-gray-500 tabular-nums">
                {String(i + 1).padStart(2, '0')}
              </span>
            </div>
            <h3
              class="mt-4 text-lg font-semibold text-gray-900 dark:text-white"
              style="font-family: 'Space Grotesk Variable', sans-serif; letter-spacing: -0.02em;"
            >
              {f.title}
            </h3>
            <p class="mt-2 text-sm text-gray-600 dark:text-gray-300 leading-relaxed flex-1">
              {f.desc}
            </p>
            <div class="mt-4 flex items-center gap-1 text-sm font-semibold text-teal-600 group-hover:text-teal-700 dark:text-teal-400 dark:group-hover:text-teal-300">
              {f.cta}
              <Icon name="tabler:arrow-right" class="h-4 w-4 transition-transform group-hover:translate-x-0.5" />
            </div>
          </a>
        ))}
      </div>

      <!-- Note about mounting -->
      <p class="mt-6 text-sm text-gray-500 dark:text-gray-400 leading-relaxed max-w-3xl">
        <span class="font-mono text-xs uppercase tracking-wider text-gray-400 dark:text-gray-500">Note:</span>
        Motor mounting type (B3 / B5 / B14 etc.) is available in the
        <a href="/structure-mounting" class="font-medium text-teal-600 hover:text-teal-700 dark:text-teal-400 dark:hover:text-teal-300">
          Structure & Mounting
        </a>
        filter facets for further fitment matching.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 4 — POPULAR PARTS (8 items)
  ═══════════════════════════════════════════════ -->
  <section class="bg-gray-50 dark:bg-slate-800/30 border-b border-gray-200 dark:border-slate-800">
    <div class="mx-auto max-w-7xl px-6 py-14 lg:py-20">
      <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-gray-500 dark:text-gray-400">
            Popular Parts
          </p>
          <h2
            class="mt-2 text-3xl font-bold text-gray-900 dark:text-white sm:text-4xl"
            style="font-family: 'Space Grotesk Variable', sans-serif; letter-spacing: -0.03em;"
          >
            High-frequency replacement parts
          </h2>
        </div>
        <a
          href={`/${waterSystem.slug}`}
          class="inline-flex items-center gap-1 text-sm font-semibold text-teal-600 hover:text-teal-700 dark:text-teal-400 dark:hover:text-teal-300"
        >
          View all parts
          <Icon name="tabler:arrow-right" class="h-4 w-4" />
        </a>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
        {popularParts.map((p) => (
          <a
            href={`/${p.systemSlug}/${p.areaSlug}/${p.productTypeSlug}/${p.slug}`}
            class="group flex flex-col overflow-hidden rounded-xl border border-gray-200 bg-white transition-all hover:border-teal-500 hover:shadow-md dark:border-slate-700 dark:bg-slate-900 dark:hover:border-teal-400"
          >
            <!-- Blueprint-style placeholder -->
            <div class="product-placeholder relative aspect-[4/3] overflow-hidden">
              <div class="absolute inset-0 flex items-center justify-center transition-transform duration-500 group-hover:scale-105">
                <Icon name="tabler:package" class="h-10 w-10 text-teal-500/40" />
              </div>
              <span class="absolute top-2.5 left-2.5 rounded bg-slate-950/70 px-2 py-0.5 font-mono text-[10px] font-semibold text-teal-400/80">
                {systemLabelMap[p.systemSlug] || 'PART'}
              </span>
            </div>
            <div class="flex flex-1 flex-col p-4">
              <p class="font-mono text-[10px] font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">
                {p.category}
              </p>
              <h3
                class="mt-1.5 text-sm font-semibold leading-snug text-gray-900 group-hover:text-teal-600 dark:text-white dark:group-hover:text-teal-400 transition-colors line-clamp-2"
                style="font-family: 'Space Grotesk Variable', sans-serif; letter-spacing: -0.01em;"
              >
                {p.name}
              </h3>
              <div class="mt-3 flex items-center justify-between border-t border-gray-100 pt-3 dark:border-slate-800">
                <span class="font-mono text-xs text-gray-500 dark:text-gray-400">MOQ {p.moq}</span>
                <span class="inline-flex items-center gap-1 text-xs font-semibold text-teal-600 dark:text-teal-400">
                  Details
                  <Icon name="tabler:arrow-right" class="h-3 w-3 transition-transform group-hover:translate-x-0.5" />
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 5 — TRUST + RFQ ACTION
  ═══════════════════════════════════════════════ -->
  <section class="bg-white dark:bg-slate-900 border-b border-gray-200 dark:border-slate-800">
    <div class="mx-auto max-w-7xl px-6 py-14 lg:py-20">
      <div class="grid gap-10 lg:grid-cols-[1fr_1.2fr] lg:gap-12">
        <!-- LEFT: 3 trust blocks -->
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-gray-500 dark:text-gray-400">
            Why teams choose EVAPFit
          </p>
          <h2
            class="mt-2 text-3xl font-bold text-gray-900 dark:text-white sm:text-4xl"
            style="font-family: 'Space Grotesk Variable', sans-serif; letter-spacing: -0.03em;"
          >
            RFQ built around
            <span class="text-teal-600 dark:text-teal-400">fitment accuracy</span>
          </h2>
          <div class="mt-8 space-y-6">
            {trustBlocks.map((t, i) => (
              <div class="flex gap-4">
                <span class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-lg bg-teal-50 text-teal-600 dark:bg-teal-500/10 dark:text-teal-400">
                  <Icon name={t.icon} class="h-4 w-4" />
                </span>
                <div>
                  <p class="font-mono text-[10px] uppercase tracking-wider text-gray-400 dark:text-gray-500">
                    {String(i + 1).padStart(2, '0')}
                  </p>
                  <h3
                    class="mt-0.5 text-base font-semibold text-gray-900 dark:text-white"
                    style="font-family: 'Space Grotesk Variable', sans-serif; letter-spacing: -0.02em;"
                  >
                    {t.title}
                  </h3>
                  <p class="mt-1 text-sm text-gray-600 dark:text-gray-300 leading-relaxed">
                    {t.desc}
                  </p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- RIGHT: Inline RFQ card -->
        <aside class="rounded-xl border border-gray-200 bg-gray-50 p-6 dark:border-slate-700 dark:bg-slate-800/50 sm:p-8">
          <div class="flex items-center gap-2">
            <Icon name="tabler:mail-fast" class="h-5 w-5 text-teal-600 dark:text-teal-400" />
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-gray-500 dark:text-gray-400">
              Tell us your requirements
            </p>
          </div>
          <h3
            class="mt-2 text-xl font-bold text-gray-900 dark:text-white"
            style="font-family: 'Space Grotesk Variable', sans-serif; letter-spacing: -0.02em;"
          >
            Start an RFQ in 60 seconds
          </h3>
          <p class="mt-2 text-sm text-gray-600 dark:text-gray-300 leading-relaxed">
            Paste your existing part number, dimensions, or specs. We'll respond with pricing, MOQ, and lead time.
          </p>

          <form class="mt-6 space-y-4" action="/inquiry" method="GET">
            <div>
              <label for="rfq-spec" class="font-mono text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">
                Part description or spec
              </label>
              <textarea
                id="rfq-spec"
                name="spec"
                rows="3"
                placeholder="e.g. 110V 550W B3 foot mount motor, 12mm shaft, 6µF capacitor"
                class="mt-1.5 w-full rounded-lg border border-gray-300 bg-white px-3 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 transition-all focus:border-teal-500 focus:outline-none focus:ring-2 focus:ring-teal-500/20 dark:border-slate-600 dark:bg-slate-900 dark:text-white dark:placeholder:text-gray-500 dark:focus:border-teal-400"
              ></textarea>
            </div>
            <div class="grid gap-3 sm:grid-cols-2">
              <div>
                <label for="rfq-name" class="font-mono text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">
                  Your name
                </label>
                <input
                  id="rfq-name"
                  type="text"
                  name="name"
                  placeholder="Full name"
                  class="mt-1.5 w-full rounded-lg border border-gray-300 bg-white px-3 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 transition-all focus:border-teal-500 focus:outline-none focus:ring-2 focus:ring-teal-500/20 dark:border-slate-600 dark:bg-slate-900 dark:text-white dark:placeholder:text-gray-500 dark:focus:border-teal-400"
                />
              </div>
              <div>
                <label for="rfq-email" class="font-mono text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">
                  Company email
                </label>
                <input
                  id="rfq-email"
                  type="email"
                  name="email"
                  placeholder="name@company.com"
                  class="mt-1.5 w-full rounded-lg border border-gray-300 bg-white px-3 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 transition-all focus:border-teal-500 focus:outline-none focus:ring-2 focus:ring-teal-500/20 dark:border-slate-600 dark:bg-slate-900 dark:text-white dark:placeholder:text-gray-500 dark:focus:border-teal-400"
                />
              </div>
            </div>
            <button
              type="submit"
              class="inline-flex w-full items-center justify-center gap-2 rounded-lg bg-teal-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition-all hover:bg-teal-700 hover:shadow-md"
            >
              <Icon name="tabler:send" class="h-4 w-4" />
              Send RFQ
            </button>
            <p class="text-xs text-gray-500 dark:text-gray-400 text-center">
              Or browse the
              <a href="/inquiry" class="font-medium text-teal-600 hover:text-teal-700 dark:text-teal-400">full inquiry form</a>
              with multiple parts.
            </p>
          </form>
        </aside>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 6 — CONTENT / GUIDE ENTRIES
  ═══════════════════════════════════════════════ -->
  <section class="bg-gray-50 dark:bg-slate-800/30 border-b border-gray-200 dark:border-slate-800">
    <div class="mx-auto max-w-7xl px-6 py-14 lg:py-20">
      <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-gray-500 dark:text-gray-400">
            Installation & Compatibility Guides
          </p>
          <h2
            class="mt-2 text-3xl font-bold text-gray-900 dark:text-white sm:text-4xl"
            style="font-family: 'Space Grotesk Variable', sans-serif; letter-spacing: -0.03em;"
          >
            Help yourself before you RFQ
          </h2>
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {contentGuides.map((g, i) => (
          <a
            href={g.href}
            class="group flex flex-col rounded-xl border border-gray-200 bg-white p-6 transition-all hover:border-teal-500 hover:shadow-md dark:border-slate-700 dark:bg-slate-900 dark:hover:border-teal-400"
          >
            <div class="flex items-start justify-between">
              <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-teal-50 text-teal-600 dark:bg-teal-500/10 dark:text-teal-400">
                <Icon name={g.icon} class="h-4 w-4" />
              </span>
              <span class="font-mono text-xs text-gray-400 dark:text-gray-500 tabular-nums">
                {String(i + 1).padStart(2, '0')}
              </span>
            </div>
            <h3
              class="mt-4 text-base font-semibold text-gray-900 group-hover:text-teal-600 dark:text-white dark:group-hover:text-teal-400 transition-colors"
              style="font-family: 'Space Grotesk Variable', sans-serif; letter-spacing: -0.02em;"
            >
              {g.title}
            </h3>
            <p class="mt-2 text-sm text-gray-600 dark:text-gray-300 leading-relaxed flex-1">
              {g.desc}
            </p>
            <div class="mt-4 flex items-center gap-1 text-sm font-semibold text-teal-600 dark:text-teal-400">
              Read guide
              <Icon name="tabler:arrow-right" class="h-4 w-4 transition-transform group-hover:translate-x-0.5" />
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 7 — BRAND STORY (Family-Built / Industry-Tested — Dial Mfg inspired)
  ═══════════════════════════════════════════════ -->
  <section class="bg-white dark:bg-slate-900">
    <div class="mx-auto max-w-7xl px-6 py-14 lg:py-20">
      <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
        <!-- LEFT: text -->
        <div>
          <h2
            class="text-3xl font-bold text-gray-900 dark:text-white sm:text-4xl"
            style="font-family: 'Space Grotesk Variable', sans-serif; letter-spacing: -0.03em;"
          >
            Industry-Tested.
            <span class="text-teal-600 dark:text-teal-400">Procurement-Ready.</span>
          </h2>
          <p class="mt-4 text-lg font-medium text-gray-700 dark:text-gray-200">
            Interface-matched parts sourced by procurement teams that don't have time for guesswork.
          </p>
          <div class="mt-6 space-y-4 text-base text-gray-600 dark:text-gray-300 leading-relaxed">
            <p>
              EVAPFit exists because matching evaporative cooler parts by model number is unreliable.
              Our catalog organizes components by <span class="font-semibold text-gray-900 dark:text-white">system</span>,
              <span class="font-semibold text-gray-900 dark:text-white">electrical specs</span>, and
              <span class="font-semibold text-gray-900 dark:text-white">structure & mounting</span>
              — so you can find a compatible replacement from measurements alone.
            </p>
            <p>
              Every part listed ships with verified interface specs and OEM-equivalent tolerances.
              We support 30+ countries with consolidated bulk shipping and flexible incoterms.
            </p>
          </div>
          <div class="mt-8 flex flex-wrap gap-3">
            <a
              href="/inquiry"
              class="inline-flex items-center justify-center gap-2 rounded-lg bg-teal-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition-all hover:bg-teal-700 hover:shadow-md"
            >
              <Icon name="tabler:mail" class="h-4 w-4" />
              Start an RFQ
            </a>
            <a
              href="/compatibility"
              class="inline-flex items-center justify-center gap-2 rounded-lg border border-gray-300 bg-white px-5 py-2.5 text-sm font-semibold text-gray-900 transition-all hover:border-teal-500 hover:text-teal-600 dark:border-slate-600 dark:bg-slate-800 dark:text-white dark:hover:border-teal-400 dark:hover:text-teal-400"
            >
              <Icon name="tabler:ruler-measure" class="h-4 w-4" />
              Compatibility Guide
            </a>
          </div>
        </div>

        <!-- RIGHT: stats card -->
        <div class="relative">
          <!-- Corner label -->
          <div class="absolute -top-3 -right-3 z-10 hidden sm:block">
            <div class="rounded-lg border border-gray-200 bg-white px-3 py-2 text-right shadow-sm dark:border-slate-700 dark:bg-slate-800">
              <p class="font-mono text-[10px] uppercase tracking-wider text-gray-500 dark:text-gray-400">
                Factory Direct Since
              </p>
              <p class="font-mono text-lg font-bold text-gray-900 dark:text-white tabular-nums">2018</p>
            </div>
          </div>

          <div class="grid grid-cols-2 gap-3">
            <div class="rounded-xl border border-gray-200 bg-gray-50 p-5 dark:border-slate-700 dark:bg-slate-800/50">
              <p class="font-mono text-3xl font-bold text-teal-600 dark:text-teal-400 tabular-nums">{String(totalParts).padStart(3, '0')}</p>
              <p class="mt-1.5 font-mono text-[10px] uppercase tracking-wider text-gray-500 dark:text-gray-400">Parts in catalog</p>
            </div>
            <div class="rounded-xl border border-gray-200 bg-gray-50 p-5 dark:border-slate-700 dark:bg-slate-800/50">
              <p class="font-mono text-3xl font-bold text-teal-600 dark:text-teal-400 tabular-nums">{String(totalTypes).padStart(2, '0')}</p>
              <p class="mt-1.5 font-mono text-[10px] uppercase tracking-wider text-gray-500 dark:text-gray-400">Product types</p>
            </div>
            <div class="rounded-xl border border-gray-200 bg-gray-50 p-5 dark:border-slate-700 dark:bg-slate-800/50">
              <p class="font-mono text-3xl font-bold text-teal-600 dark:text-teal-400 tabular-nums">24h</p>
              <p class="mt-1.5 font-mono text-[10px] uppercase tracking-wider text-gray-500 dark:text-gray-400">RFQ response</p>
            </div>
            <div class="rounded-xl border border-gray-200 bg-gray-50 p-5 dark:border-slate-700 dark:bg-slate-800/50">
              <p class="font-mono text-3xl font-bold text-teal-600 dark:text-teal-400 tabular-nums">30+</p>
              <p class="mt-1.5 font-mono text-[10px] uppercase tracking-wider text-gray-500 dark:text-gray-400">Countries shipped</p>
            </div>
          </div>

          <!-- Compliance bar -->
          <div class="mt-3 flex flex-wrap items-center justify-between gap-3 rounded-xl border border-gray-200 bg-white px-5 py-3 dark:border-slate-700 dark:bg-slate-900">
            <span class="font-mono text-[10px] uppercase tracking-wider text-gray-500 dark:text-gray-400">Compliance</span>
            <div class="flex flex-wrap items-center gap-x-4 gap-y-1 font-mono text-xs text-gray-600 dark:text-gray-300">
              <span>ISO 9001</span>
              <span class="h-3 w-px bg-gray-300 dark:bg-slate-700"></span>
              <span>CE</span>
              <span class="h-3 w-px bg-gray-300 dark:bg-slate-700"></span>
              <span>RoHS</span>
              <span class="h-3 w-px bg-gray-300 dark:bg-slate-700"></span>
              <span>12-mo warranty</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
