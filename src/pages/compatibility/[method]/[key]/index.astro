---
import Layout from '~/layouts/InquiryLayout.astro';
import { Icon } from 'astro-icon/components';
import { getAllProducts } from '~/data/product-helpers';
import ProductCard from '~/components/inquiry/ProductCard.astro';

export async function getStaticPaths() {
  const paths: { params: { method: string; key: string } }[] = [];

  // Interface keys
  const interfaceKeys = ['threaded-connection', 'push-fit', 'flange-mount', 'hose-barb', 'clamp-mount'];
  for (const key of interfaceKeys) {
    paths.push({ params: { method: 'interface', key } });
  }

  // Dimension keys
  const dimKeys = ['600mm-pad', '12mm-shaft', '10mm-pipe', '1-2-inch-port', '250mm-wheel'];
  for (const key of dimKeys) {
    paths.push({ params: { method: 'dimensions', key } });
  }

  // Electrical keys
  for (const v of ['110v', '220v', '380v']) {
    for (const p of ['250w', '550w', '750w']) {
      for (const r of ['900rpm', '1400rpm', '2800rpm']) {
        paths.push({ params: { method: 'electrical', key: `${v}-${p}-${r}` } });
      }
    }
  }

  // Cross-reference keys
  const xrefKeys = ['pump-seal', 'motor-capacitor', 'pad-frame', 'fan-guard'];
  for (const key of xrefKeys) {
    paths.push({ params: { method: 'cross-reference', key } });
  }

  return paths;
}

const { method, key } = Astro.params;

// Filter products by method and key
const productsData = await getAllProducts();
const filtered = productsData.filter((p) => {
  const specs = p.specs.map((s) => `${s.label}:${s.value}`.toLowerCase());
  const compat = p.compatibility.map((c) => c.toLowerCase());
  const all = [...specs, ...compat, p.name.toLowerCase(), p.description.toLowerCase()];

  if (method === 'interface') {
    const term = key!.replace(/-/g, ' ');
    return all.some((s) => s.includes(term));
  }
  if (method === 'dimensions') {
    const term = key!.replace(/-/g, ' ');
    return all.some((s) => s.includes(term));
  }
  if (method === 'electrical') {
    const [v, p, r] = key!.split('-');
    return specs.some((s) => s.includes(v)) || specs.some((s) => s.includes(p)) || specs.some((s) => s.includes(r));
  }
  if (method === 'cross-reference') {
    const term = key!.replace(/-/g, ' ');
    return all.some((s) => s.includes(term));
  }
  return false;
});

const methodLabels: Record<string, string> = { interface: 'Interface', dimensions: 'Dimensions', electrical: 'Electrical', 'cross-reference': 'Cross-reference' };
const keyLabel = key!.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
---

<Layout metadata={{ title: `Compatible by ${methodLabels[method!]}: ${keyLabel} — EVAPFit`, ignoreTitleTemplate: true }}>
  <!-- Breadcrumb -->
  <div class="border-b border-gray-100 bg-white dark:border-slate-800 dark:bg-slate-900">
    <div class="mx-auto max-w-7xl px-6 py-3 text-sm text-muted flex items-center breadcrumb-scroll">
      <a href="/" class="hover:text-teal-600 dark:hover:text-teal-400 transition-colors">Home</a>
      <span class="mx-1.5 text-gray-300 dark:text-slate-600">/</span>
      <a href="/compatibility" class="hover:text-teal-600 dark:hover:text-teal-400 transition-colors">Compatibility</a>
      <span class="mx-1.5 text-gray-300 dark:text-slate-600">/</span>
      <a href={`/compatibility/${method}`} class="hover:text-teal-600 dark:hover:text-teal-400 transition-colors">{methodLabels[method!]}</a>
      <span class="mx-1.5 text-gray-300 dark:text-slate-600">/</span>
      <span class="text-gray-700 dark:text-gray-300">{keyLabel}</span>
    </div>
  </div>

  <!-- Header — text-driven, no gradient -->
  <section class="border-b border-gray-100 bg-white dark:border-slate-800 dark:bg-slate-900">
    <div class="mx-auto max-w-7xl px-6 py-12 lg:py-16">
      <div data-reveal>
        <p class="text-sm font-medium text-teal-600 dark:text-teal-400">{methodLabels[method!]} Match</p>
        <h1
          class="mt-2 text-2xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-3xl"
          style="font-family: 'Space Grotesk Variable', sans-serif; letter-spacing: -0.02em;"
        >
          {keyLabel}
        </h1>
        <p class="mt-3 text-sm text-muted">{filtered.length} matching product{filtered.length !== 1 ? 's' : ''} found</p>
      </div>
    </div>
  </section>

  <!-- Products -->
  <section class="bg-white dark:bg-slate-900">
    <div class="mx-auto max-w-7xl px-6 py-12 lg:py-16">
      {filtered.length > 0 ? (
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          {filtered.map((product) => (
            <ProductCard product={product} />
          ))}
        </div>
      ) : (
        <div class="flex flex-col items-center py-16 text-center">
          <Icon name="tabler:search-off" class="h-12 w-12 text-gray-300 dark:text-slate-600" />
          <h3 class="mt-4 text-base font-semibold text-gray-900 dark:text-white" style="font-family: 'Space Grotesk Variable', sans-serif;">No exact matches found</h3>
          <p class="mt-2 text-sm text-muted">Try a broader search or submit a general inquiry with your specifications.</p>
          <a href="/inquiry" class="mt-4 inline-flex items-center gap-2 rounded-lg bg-teal-600 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-teal-500">
            <Icon name="tabler:mail" class="h-4 w-4" />
            Submit Inquiry
          </a>
        </div>
      )}
    </div>
  </section>
</Layout>
