---
import Layout from '~/layouts/InquiryLayout.astro';
import { Icon } from 'astro-icon/components';
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import StructuredData from '~/components/common/StructuredData.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('post');
  return allPosts.map((post) => ({
    params: { slug: post.id.replace(/\.(md|mdx)$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props as { post: CollectionEntry<'post'> };
const { Content } = await render(post);

const title = post.data.title;
const excerpt = post.data.excerpt || '';
const publishDate = post.data.publishDate
  ? new Date(post.data.publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : '';
const isoPublishDate = post.data.publishDate ? new Date(post.data.publishDate).toISOString() : '';
const isoModifiedDate = (post.data as any).updateDate
  ? new Date((post.data as any).updateDate).toISOString()
  : isoPublishDate;
const modifiedDateDisplay = (post.data as any).updateDate
  ? new Date((post.data as any).updateDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : '';
const category = post.data.category || '';
const tags = post.data.tags || [];
const image = post.data.image || '';
const author = (post.data as any).author || 'EVAPFit';
---

<Layout metadata={{ title: `${title} | EVAPFit Blog`, description: excerpt, ignoreTitleTemplate: true }}>
  <StructuredData type="BreadcrumbList" items={[
    { name: 'Home', url: '/' },
    { name: 'Blog', url: '/blog' },
    { name: title, url: `/blog/${post.id.replace(/\.(md|mdx)$/, '')}` },
  ]} />
  <StructuredData type="Article" article={{
    title,
    description: excerpt,
    image: image || undefined,
    datePublished: isoPublishDate,
    dateModified: isoModifiedDate,
    author,
  }} />
  <!-- Breadcrumb -->
  <div class="border-b border-gray-100 bg-white dark:border-slate-800 dark:bg-slate-900">
    <div class="mx-auto max-w-3xl px-6 py-2.5 text-sm text-muted">
      <a href="/" class="hover:text-teal-600">Home</a>
      <span class="mx-1.5 text-gray-300">/</span>
      <a href="/blog" class="hover:text-teal-600">Blog</a>
      <span class="mx-1.5 text-gray-300">/</span>
      <span class="text-gray-700 dark:text-gray-300">{title}</span>
    </div>
  </div>

  <!-- Article Header -->
  <section class="bg-white dark:bg-slate-900">
    <div class="mx-auto max-w-3xl px-6 pt-10 pb-6 lg:pt-14">
      <div class="flex flex-wrap items-center gap-3 text-sm text-muted mb-4">
        {publishDate && (
          <span class="inline-flex items-center gap-1.5">
            <Icon name="tabler:calendar" class="h-4 w-4" />
            {publishDate}
          </span>
        )}
        {modifiedDateDisplay && modifiedDateDisplay !== publishDate && (
          <span class="inline-flex items-center gap-1.5 text-xs text-muted">
            <Icon name="tabler:pencil" class="h-3.5 w-3.5" />
            Updated {modifiedDateDisplay}
          </span>
        )}
        {category && (
          <span class="rounded-full bg-teal-50 px-3 py-0.5 text-xs font-medium text-teal-700 dark:bg-teal-900/20 dark:text-teal-400">
            {category}
          </span>
        )}
      </div>
      <h1 class="text-3xl font-extrabold tracking-tight text-gray-900 dark:text-white sm:text-4xl" style="font-family: 'Space Grotesk Variable', sans-serif; letter-spacing: -0.02em;">
        {title}
      </h1>
      {excerpt && (
        <p class="mt-4 text-lg text-muted leading-relaxed">{excerpt}</p>
      )}
      {image && (
        <div class="mt-8 overflow-hidden rounded-xl">
          <img src={image} alt={title} class="w-full object-cover" loading="lazy" />
        </div>
      )}
    </div>
  </section>

  <!-- Article Body -->
  <section class="bg-white dark:bg-slate-900">
    <div class="mx-auto max-w-3xl px-6 pb-12 lg:pb-16">
      <div class="prose dark:prose-invert max-w-none prose-headings:font-bold prose-h2:text-xl prose-h2:mt-10 prose-h3:text-lg prose-a:text-teal-600 prose-a:no-underline hover:prose-a:underline prose-img:rounded-lg">
        <Content />
      </div>

      <!-- Tags -->
      {tags.length > 0 && (
        <div class="mt-10 flex flex-wrap gap-2 border-t border-gray-100 pt-6 dark:border-slate-800">
          {tags.map((tag: string) => (
            <span class="rounded-full bg-gray-100 px-3 py-1 text-xs text-muted dark:bg-slate-800">{tag}</span>
          ))}
        </div>
      )}

      <!-- Back to Blog -->
      <div class="mt-8">
        <a href="/blog" class="inline-flex items-center gap-2 text-sm font-medium text-teal-600 hover:text-teal-700 dark:text-teal-400">
          <Icon name="tabler:arrow-left" class="h-4 w-4" />
          Back to Blog
        </a>
      </div>
    </div>
  </section>
</Layout>
