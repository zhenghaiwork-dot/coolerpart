---
import Layout from '~/layouts/InquiryLayout.astro';
import { Icon } from 'astro-icon/components';
import { systemsData } from '~/data/systems';
import { getProductsByArea, getProductTypeMeta } from '~/data/product-helpers';
import ProductCard from '~/components/inquiry/ProductCard.astro';
import type { System, SystemArea } from '~/data/inquiry-types';

export async function getStaticPaths() {
  const paths: { params: { system: string; area: string }; props: { system: System; area: SystemArea } }[] = [];
  for (const system of systemsData) {
    for (const area of system.areas) {
      paths.push({ params: { system: system.slug, area: area.slug }, props: { system, area } });
    }
  }
  return paths;
}

const { system, area } = Astro.props;
const productTypes = await getProductTypeMeta(system.slug, area.slug);
const allProducts = await getProductsByArea(system.slug, area.slug);
const relatedAreas = system.areas.filter((a) => a.slug !== area.slug).slice(0, 4);
---

<Layout metadata={{
  title: `${area.name} Replacement Parts for Evaporative Air Coolers`,
  description: `Find compatible ${area.name.toLowerCase()} replacement parts for evaporative air coolers. ${area.description} Match specifications and request a bulk quote.`,
  ignoreTitleTemplate: true,
}}>
  <!-- Breadcrumb -->
  <div class="border-b border-gray-100 bg-white dark:border-slate-800 dark:bg-slate-900">
    <div class="mx-auto max-w-7xl px-6 py-2.5 text-sm text-muted">
      <a href="/" class="hover:text-teal-600">Home</a>
      <span class="mx-1.5 text-gray-300">/</span>
      <a href={`/${system.slug}`} class="hover:text-teal-600">{system.name}</a>
      <span class="mx-1.5 text-gray-300">/</span>
      <span class="text-gray-700 dark:text-gray-300">{area.name}</span>
    </div>
  </div>

  <!-- Header -->
  <section class="border-b border-gray-100 bg-white dark:border-slate-800 dark:bg-slate-900">
    <div class="mx-auto max-w-7xl px-6 py-10 lg:py-14">
      <p class="text-xs font-medium uppercase tracking-wide text-teal-600 dark:text-teal-400 mb-1">{system.name}</p>
      <h1 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-3xl">{area.name} Replacement Parts for Evaporative Air Coolers</h1>
      <p class="mt-2 max-w-2xl text-sm text-muted leading-relaxed">{area.description}</p>
      <p class="mt-3 text-xs text-muted">{allProducts.length} products in {productTypes.length} types</p>
    </div>
  </section>

  <!-- SEO text -->
  <section class="border-b border-gray-100 bg-gray-50 dark:border-slate-800 dark:bg-slate-800/30">
    <div class="mx-auto max-w-7xl px-6 py-4">
      <p class="text-sm text-muted leading-relaxed max-w-3xl">
        Find compatible <strong class="text-gray-800 dark:text-gray-200">{area.name.toLowerCase()}</strong> for portable and cabinet evaporative coolers. Match by connection type, key dimensions, or electrical parameters without needing a model number. <a href="/compatibility" class="text-teal-600 hover:underline">Learn about our compatibility system &rarr;</a>
      </p>
    </div>
  </section>

  <!-- Product Types -->
  <section class="bg-white dark:bg-slate-900">
    <div class="mx-auto max-w-7xl px-6 py-10 lg:py-14">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-1">Browse by Product Type</h2>
      <p class="text-sm text-muted mb-6">Select a product type to view specific replacement parts.</p>
      {productTypes.length > 0 ? (
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {productTypes.map((type) => (
            <a
              href={`/${system.slug}/${area.slug}/${type.slug}`}
              class="group flex items-start gap-3 rounded-lg border border-gray-200 bg-white p-4 transition hover:border-gray-300 hover:shadow-sm dark:border-slate-700 dark:bg-slate-800/50"
            >
              <Icon name={area.icon} class="h-5 w-5 text-teal-500 mt-0.5 flex-shrink-0" />
              <div class="min-w-0">
                <span class="text-sm font-medium text-gray-900 dark:text-white group-hover:text-teal-600">{type.name}</span>
                <p class="text-xs text-muted mt-0.5 line-clamp-2">{type.description}</p>
                <p class="text-xs text-teal-600 dark:text-teal-400 mt-1">{type.productCount} product{type.productCount !== 1 ? 's' : ''}</p>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-sm text-muted py-8 text-center">No product types listed yet. <a href="/inquiry" class="text-teal-600 hover:underline">Submit an inquiry</a>.</p>
      )}
    </div>
  </section>

  {/* All Products */}
  {allProducts.length > 0 && (
    <section class="border-t border-gray-100 bg-gray-50 dark:border-slate-700 dark:bg-slate-800/30">
      <div class="mx-auto max-w-7xl px-6 py-10 lg:py-14">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-1">All {area.name} Products</h2>
        <p class="text-sm text-muted mb-6">{allProducts.length} compatible replacement part{allProducts.length !== 1 ? 's' : ''}. Click any product for detailed specs and to request a quote.</p>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          {allProducts.map((product) => (<ProductCard product={product} />))}
        </div>
      </div>
    </section>
  )}

  {/* Related Areas */}
  {relatedAreas.length > 0 && (
    <section class="border-t border-gray-100 bg-white dark:border-slate-800 dark:bg-slate-900">
      <div class="mx-auto max-w-7xl px-6 py-10 lg:py-14">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Related Categories in {system.name}</h2>
        <div class="grid gap-2 sm:grid-cols-2 lg:grid-cols-4">
          {relatedAreas.map((ra) => (
            <a href={`/${system.slug}/${ra.slug}`} class="flex items-center gap-2 rounded-lg border border-gray-200 bg-white px-4 py-3 text-sm font-medium text-gray-700 hover:border-teal-300 hover:text-teal-600 transition dark:border-slate-700 dark:bg-slate-800/50 dark:text-gray-300">
              <Icon name={ra.icon} class="h-4 w-4 text-teal-500 flex-shrink-0" />
              <span class="truncate">{ra.name}</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="bg-slate-950 text-white">
    <div class="mx-auto max-w-3xl px-6 py-12 text-center lg:py-16">
      <h2 class="text-xl font-semibold">Can't find the exact part?</h2>
      <p class="mt-3 text-sm text-gray-400 max-w-xl mx-auto">Send us your measurements and photos — we'll identify the correct replacement and provide a quote within 24 hours.</p>
      <div class="mt-6 flex flex-col items-center gap-2.5 sm:flex-row sm:justify-center">
        <a href="/inquiry" class="rounded-lg bg-teal-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-teal-500">Submit Inquiry</a>
        <a href="/how-to-identify-part-number" class="rounded-lg border border-white/15 px-5 py-2.5 text-sm font-semibold text-white hover:bg-white/5">How to Identify Parts</a>
      </div>
    </div>
  </section>
</Layout>
