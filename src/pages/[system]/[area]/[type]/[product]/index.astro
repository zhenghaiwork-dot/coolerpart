---
import Layout from '~/layouts/InquiryLayout.astro';
import { Icon } from 'astro-icon/components';
import { productsData } from '~/data/products';
import { systemsData } from '~/data/systems';
import type { Product } from '~/data/inquiry-types';

export async function getStaticPaths() {
  const paths: { params: { system: string; area: string; type: string; product: string }; props: { product: Product } }[] = [];
  for (const product of productsData) {
    paths.push({
      params: { system: product.systemSlug, area: product.areaSlug, type: product.productTypeSlug, product: product.slug },
      props: { product },
    });
  }
  return paths;
}

const { product } = Astro.props;
const system = systemsData.find((s) => s.slug === product.systemSlug);
const area = system?.areas.find((a) => a.slug === product.areaSlug);
const typeName = product.category;

const relatedProducts = productsData.filter((p) => p.slug !== product.slug && p.productTypeSlug === product.productTypeSlug).slice(0, 4);
const crossSell = productsData.filter((p) => p.slug !== product.slug && p.areaSlug === product.areaSlug && p.productTypeSlug !== product.productTypeSlug).slice(0, 4);
---

<Layout metadata={{
  title: `${product.name} | Evaporative Air Cooler Replacement Part`,
  description: `${product.description} Check compatibility, specifications, MOQ and indicative pricing for this evaporative air cooler replacement part, then request a quote.`,
  ignoreTitleTemplate: true,
}}>
  <!-- Breadcrumb -->
  <div class="border-b border-gray-100 bg-white dark:border-slate-800 dark:bg-slate-900">
    <div class="mx-auto max-w-7xl px-6 py-2.5 text-sm text-muted">
      <a href="/" class="hover:text-teal-600">Home</a>
      {system && (<><span class="mx-1.5 text-gray-300">/</span><a href={`/${system.slug}`} class="hover:text-teal-600">{system.name}</a></>)}
      {area && (<><span class="mx-1.5 text-gray-300">/</span><a href={`/${system!.slug}/${area.slug}`} class="hover:text-teal-600">{area.name}</a></>)}
      <span class="mx-1.5 text-gray-300">/</span><a href={`/${product.systemSlug}/${product.areaSlug}/${product.productTypeSlug}`} class="hover:text-teal-600">{typeName}</a>
      <span class="mx-1.5 text-gray-300">/</span><span class="text-gray-700 dark:text-gray-300">{product.name}</span>
    </div>
  </div>

  <!-- Product Hero -->
  <section class="bg-white dark:bg-slate-900">
    <div class="mx-auto max-w-7xl px-6 py-8 sm:py-10 lg:py-12">
      <div class="grid gap-8 lg:grid-cols-2 lg:gap-10">
        <!-- Image placeholder -->
        <div class="aspect-square overflow-hidden rounded-xl bg-gradient-to-br from-slate-50 to-slate-100 dark:from-slate-800 dark:to-slate-700 flex items-center justify-center">
          <Icon name="tabler:package" class="h-24 w-24 text-slate-300 dark:text-slate-600" />
        </div>

        <!-- Info -->
        <div class="flex flex-col justify-center">
          <span class="mb-2 inline-flex items-center gap-1.5 rounded-full bg-teal-50 px-2.5 py-0.5 text-xs font-medium text-teal-700 dark:bg-teal-900/30 dark:text-teal-400 w-fit">
            {product.category}
          </span>
          <h1 class="text-xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-2xl lg:text-3xl">{product.name} for Evaporative Air Coolers</h1>
          <p class="mt-3 text-sm leading-relaxed text-muted">{product.longDescription}</p>

          <!-- Compatibility snapshot -->
          {product.compatibility.length > 0 && (
            <div class="mt-5 rounded-xl border border-teal-200 bg-teal-50/50 p-4 dark:border-teal-800 dark:bg-teal-900/10">
              <p class="text-xs font-semibold text-teal-800 dark:text-teal-300 mb-2">Quick Compatibility Snapshot</p>
              <div class="flex flex-wrap gap-1.5">
                {product.compatibility.map((item) => (
                  <span class="inline-flex items-center gap-1 rounded-md border border-teal-300 bg-white px-2 py-0.5 text-xs font-medium text-teal-700 dark:border-teal-700 dark:bg-teal-900/20 dark:text-teal-300">&#x2713; {item}</span>
                ))}
              </div>
            </div>
          )}

          <!-- CTA Buttons -->
          <div class="mt-6 flex flex-col gap-2.5 sm:flex-row">
            <button
              id="request-quote-btn"
              data-product-slug={product.slug}
              data-product-name={product.name}
              data-product-category={product.category}
              data-product-moq={product.moq}
              data-product-price={product.priceRange}
              class="inline-flex items-center justify-center gap-2 rounded-lg bg-teal-600 px-6 py-2.5 text-sm font-semibold text-white hover:bg-teal-500 transition"
            >
              <Icon name="tabler:mail" class="h-4 w-4" /> Request Quote &rarr;
            </button>
            <button
              id="add-to-basket-btn"
              data-product-slug={product.slug}
              data-product-name={product.name}
              data-product-category={product.category}
              data-product-moq={product.moq}
              data-product-price={product.priceRange}
              class="inline-flex items-center justify-center gap-2 rounded-lg border border-gray-200 bg-white px-6 py-2.5 text-sm font-semibold text-gray-700 hover:border-gray-300 hover:bg-gray-50 transition dark:border-slate-600 dark:bg-slate-800 dark:text-gray-300"
            >
              <Icon name="tabler:clipboard-plus" class="h-4 w-4" /> Add to Inquiry List
            </button>
          </div>
          <div id="added-feedback" class="mt-2.5 hidden items-center gap-2 text-xs font-medium text-emerald-600 dark:text-emerald-400">
            <Icon name="tabler:circle-check" class="h-3.5 w-3.5" /> Added to your inquiry list
          </div>

          <!-- MOQ / Price / Lead Time -->
          <div class="mt-5 grid grid-cols-3 gap-px overflow-hidden rounded-lg border border-gray-200 bg-gray-200 dark:border-slate-700 dark:bg-slate-700">
            <div class="bg-white p-3.5 dark:bg-slate-800"><span class="text-xs text-muted">MOQ</span><p class="text-sm font-semibold text-gray-900 dark:text-white mt-0.5">{product.moq}</p></div>
            <div class="bg-white p-3.5 dark:bg-slate-800"><span class="text-xs text-muted">Price</span><p class="text-sm font-semibold text-gray-900 dark:text-white mt-0.5">{product.priceRange}</p></div>
            <div class="bg-white p-3.5 dark:bg-slate-800"><span class="text-xs text-muted">Lead Time</span><p class="text-sm font-semibold text-gray-900 dark:text-white mt-0.5">7-15 Days</p></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Key Specifications -->
  {product.specs.length > 0 && (
    <section class="border-t border-gray-100 bg-gray-50 dark:border-slate-700 dark:bg-slate-800/30">
      <div class="mx-auto max-w-7xl px-6 py-8 sm:py-10">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Key Specifications</h2>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {product.specs.map((spec) => (
            <div class="rounded-lg border border-gray-200 bg-white p-3.5 dark:border-slate-700 dark:bg-slate-800">
              <span class="text-xs font-medium uppercase tracking-wider text-muted">{spec.label}</span>
              <p class="mt-1 text-base font-semibold text-gray-900 dark:text-white">{spec.value}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Features -->
  {product.features.length > 0 && (
    <section class="border-t border-gray-100 bg-white dark:border-slate-800 dark:bg-slate-900">
      <div class="mx-auto max-w-7xl px-6 py-8 sm:py-10">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Features & Benefits</h2>
        <div class="grid gap-4 sm:grid-cols-2">
          {product.features.map((feature) => (
            <div class="flex gap-3 rounded-lg border border-gray-100 bg-gray-50/50 p-4 dark:border-slate-700 dark:bg-slate-800/30">
              <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg bg-teal-100 text-teal-600 dark:bg-teal-900/30 dark:text-teal-400">
                <Icon name="tabler:check" class="h-4 w-4" />
              </div>
              <div>
                <h3 class="text-sm font-semibold text-gray-900 dark:text-white">{feature.title}</h3>
                <p class="mt-0.5 text-xs text-muted leading-relaxed">{feature.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Typical Applications -->
  <section class="border-t border-gray-100 bg-gray-50 dark:border-slate-700 dark:bg-slate-800/30">
    <div class="mx-auto max-w-7xl px-6 py-8 sm:py-10">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-3">Typical Applications</h2>
      <p class="text-sm text-muted leading-relaxed max-w-2xl">Portable evaporative air coolers (cabinet type) &middot; Fixed installation cooling units &middot; Replacement and maintenance service applications</p>
    </div>
  </section>

  <!-- Dimensions & Interface -->
  <section class="border-t border-gray-100 bg-white dark:border-slate-800 dark:bg-slate-900">
    <div class="mx-auto max-w-7xl px-6 py-8 sm:py-10">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-3">Dimensions & Interface</h2>
      <p class="text-sm text-muted leading-relaxed max-w-2xl mb-3">Verify your existing component's interface type, mounting pattern, and connection size match before ordering. Refer to the specification table above for key mating dimensions.</p>
      <ul class="text-sm text-muted space-y-1">
        <li>&bull; Confirm interface type: threaded / flange / push-fit / bracket</li>
        <li>&bull; Check mounting dimensions and bolt patterns</li>
        <li>&bull; Contact us with photos if unsure about fitment</li>
      </ul>
    </div>
  </section>

  <!-- Materials -->
  <section class="border-t border-gray-100 bg-gray-50 dark:border-slate-700 dark:bg-slate-800/30">
    <div class="mx-auto max-w-7xl px-6 py-8 sm:py-10">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-3">Materials & Construction</h2>
      <p class="text-sm text-muted leading-relaxed max-w-2xl">Industrial-grade materials selected for wet, continuous-duty environments. Corrosion-resistant treatment and QC inspection before assembly.</p>
    </div>
  </section>

  <!-- Installation -->
  <section class="border-t border-gray-100 bg-white dark:border-slate-800 dark:bg-slate-900">
    <div class="mx-auto max-w-7xl px-6 py-8 sm:py-10">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Installation & Replacement Notes</h2>
      <div class="max-w-2xl space-y-3">
        <div class="flex gap-3 text-sm"><span class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded bg-teal-600 text-xs font-bold text-white">1</span><p class="text-muted pt-0.5">Disconnect power and water supply before beginning replacement.</p></div>
        <div class="flex gap-3 text-sm"><span class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded bg-teal-600 text-xs font-bold text-white">2</span><p class="text-muted pt-0.5">Check interface type and dimensions match. Refer to specifications above.</p></div>
        <div class="flex gap-3 text-sm"><span class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded bg-teal-600 text-xs font-bold text-white">3</span><p class="text-muted pt-0.5">Install using same mounting method. Ensure seals and gaskets are properly seated.</p></div>
        <div class="flex gap-3 text-sm"><span class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded bg-teal-600 text-xs font-bold text-white">4</span><p class="text-muted pt-0.5">Test operation before returning to full service. Check for leaks and proper function.</p></div>
      </div>
      <p class="mt-4 text-xs text-amber-700 dark:text-amber-400 bg-amber-50 dark:bg-amber-900/10 rounded-lg p-3 max-w-2xl"><strong>Note:</strong> Differences in interface or mounting may require adapter components. Confirm measurements before ordering.</p>
    </div>
  </section>

  <!-- OEM -->
  <section class="border-t border-gray-100 bg-gray-50 dark:border-slate-700 dark:bg-slate-800/30">
    <div class="mx-auto max-w-7xl px-6 py-8 sm:py-10">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-3">OEM & Customization</h2>
      <p class="text-sm text-muted max-w-2xl">Custom specs, private labeling, and packaging available for qualifying order volumes. <a href="/oem" class="text-teal-600 hover:underline">Learn more about OEM options &rarr;</a></p>
    </div>
  </section>

  <!-- Warranty -->
  <section class="border-t border-gray-100 bg-white dark:border-slate-800 dark:bg-slate-900">
    <div class="mx-auto max-w-7xl px-6 py-8 sm:py-10">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-3">Warranty & Quality</h2>
      <p class="text-sm text-muted max-w-2xl">12-month standard warranty against manufacturing defects. OEM-equivalent specifications. 100% tested before shipment. Extended warranty available for bulk orders.</p>
    </div>
  </section>

  <!-- Related Products -->
  {relatedProducts.length > 0 && (
    <section class="border-t border-gray-100 bg-gray-50 dark:border-slate-700 dark:bg-slate-800/30">
      <div class="mx-auto max-w-7xl px-6 py-8 sm:py-10">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Similar Products</h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {relatedProducts.map((rp) => (
            <a href={`/${rp.systemSlug}/${rp.areaSlug}/${rp.productTypeSlug}/${rp.slug}`} class="group rounded-lg border border-gray-200 bg-white p-4 transition hover:shadow-sm dark:border-slate-700 dark:bg-slate-800/50">
              <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-gray-100 dark:bg-slate-700 mb-2">
                <Icon name="tabler:components" class="h-5 w-5 text-gray-400" />
              </div>
              <h3 class="text-sm font-semibold text-gray-900 group-hover:text-teal-600 dark:text-white">{rp.name}</h3>
              <p class="mt-1 text-xs text-muted line-clamp-2">{rp.description}</p>
              <span class="mt-2 inline-block text-xs text-teal-600 dark:text-teal-400">View Details &rarr;</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Cross-sell -->
  {crossSell.length > 0 && (
    <section class="border-t border-gray-100 bg-white dark:border-slate-800 dark:bg-slate-900">
      <div class="mx-auto max-w-7xl px-6 py-8 sm:py-10">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">You May Also Need</h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {crossSell.map((item) => (
            <a href={`/${item.systemSlug}/${item.areaSlug}/${item.productTypeSlug}/${item.slug}`} class="group rounded-lg border border-gray-200 bg-white p-4 transition hover:shadow-sm dark:border-slate-700 dark:bg-slate-800/50">
              <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-gray-100 dark:bg-slate-700 mb-2">
                <Icon name="tabler:components" class="h-5 w-5 text-gray-400" />
              </div>
              <h3 class="text-sm font-semibold text-gray-900 group-hover:text-teal-600 dark:text-white">{item.name}</h3>
              <p class="mt-1 text-xs text-muted line-clamp-2">{item.description}</p>
              <span class="mt-2 inline-block text-xs text-teal-600 dark:text-teal-400">View Details &rarr;</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Sticky bottom bar -->
  <div class="sticky bottom-0 z-30 border-t border-gray-200 bg-white/95 backdrop-blur dark:border-slate-700 dark:bg-slate-900/95">
    <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-3">
      <div>
        <p class="text-sm font-semibold text-gray-900 dark:text-white truncate max-w-[200px] sm:max-w-xs">{product.name}</p>
        <p class="text-xs text-muted">{product.moq}</p>
      </div>
      <button class="sticky-quote-btn inline-flex items-center gap-1.5 rounded-lg bg-teal-600 px-4 py-2 text-sm font-semibold text-white hover:bg-teal-500"
        data-product-slug={product.slug}
        data-product-name={product.name}
        data-product-category={product.category}
        data-product-moq={product.moq}
        data-product-price={product.priceRange}>
        <Icon name="tabler:mail" class="h-3.5 w-3.5" /> Request Quote
      </button>
    </div>
  </div>
</Layout>

<script>
  import { addToBasket, getProductData, isInBasket } from "~/scripts/inquiry-basket";

  function initProductPage() {
    const requestQuoteBtn = document.getElementById("request-quote-btn");
    const addBtn = document.getElementById("add-to-basket-btn");
    const feedback = document.getElementById("added-feedback");
    const stickyBtns = document.querySelectorAll(".sticky-quote-btn");

    function updateAddButtonState() {
      if (!addBtn) return;
      const slug = addBtn.dataset.productSlug;
      if (slug && isInBasket(slug)) {
        addBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path d="M5 12l5 5l10-10"/></svg> In Your Inquiry List';
        addBtn.classList.add("opacity-70", "cursor-default", "border-emerald-300", "bg-emerald-50", "text-emerald-700");
        addBtn.classList.remove("border-gray-200", "bg-white", "text-gray-700", "hover:border-gray-300", "hover:bg-gray-50");
      }
    }

    requestQuoteBtn?.addEventListener("click", () => {
      addToBasket(getProductData(requestQuoteBtn));
      window.location.href = "/inquiry";
    });

    addBtn?.addEventListener("click", () => {
      const added = addToBasket(getProductData(addBtn));
      if (added && feedback) { feedback.classList.remove("hidden"); setTimeout(() => feedback.classList.add("hidden"), 3000); }
      updateAddButtonState();
    });

    stickyBtns.forEach((btn) => {
      btn.addEventListener("click", () => { addToBasket(getProductData(btn)); window.location.href = "/inquiry"; });
    });

    updateAddButtonState();
  }

  document.addEventListener("astro:page-load", initProductPage);
  window.addEventListener("pageshow", (e) => { if (e.persisted) initProductPage(); });
  window.addEventListener("inquiry-basket:update", initProductPage);
  initProductPage();
</script>
