---
import Layout from '~/layouts/InquiryLayout.astro';
import { Icon } from 'astro-icon/components';
const faqs = [
  { q: 'Do I need a model number to find the right part?', a: 'No. Our interface-first system helps you find compatible parts by connection type, dimensions, and electrical specs — no model number needed.' },
  { q: 'What is the minimum order quantity (MOQ)?', a: 'MOQ varies by product type. Most parts start at 10-50 pcs. Sample orders (1-2 pcs) are available for evaluation. Check individual product pages for specific MOQ values.' },
  { q: 'Can I get samples before placing a bulk order?', a: 'Yes. Sample orders ship within 3-5 working days via express courier. Sample cost is refundable against your first bulk order.' },
  { q: 'Do you offer OEM / private labeling?', a: 'Yes. We provide custom specifications, branding, labeling, and packaging for qualifying order volumes. Visit our OEM page for details.' },
  { q: 'What payment methods do you accept?', a: 'T/T (bank transfer), L/C at sight, and Western Union for samples. Payment terms: 30% deposit, 70% before shipment for new customers.' },
  { q: 'What warranty do you provide?', a: 'Standard 12-month warranty against manufacturing defects. Extended warranty available for bulk/OEM orders upon agreement.' },
  { q: 'How long does shipping take?', a: 'Air freight: 5-10 days. Sea freight: 15-45 days. Express courier: 3-7 days. Exact transit time depends on your destination.' },
  { q: 'Do you provide technical support?', a: 'Yes. Our engineering team can assist with part identification, compatibility confirmation, and installation guidance.' },
];
---
<Layout metadata={{ title: 'FAQ — EVAPFit', ignoreTitleTemplate: true }}>
  <section class="overflow-hidden bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white">
    <div class="mx-auto max-w-3xl px-4 py-16 text-center sm:px-6 sm:py-20">
      <h1 class="text-3xl font-extrabold tracking-tight sm:text-4xl">Frequently Asked Questions</h1>
      <p class="mt-4 text-lg text-gray-300">Quick answers to common questions about our products, ordering, and shipping.</p>
    </div>
  </section>
  <section class="bg-white dark:bg-slate-900">
    <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6 sm:py-16">
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="group rounded-xl border border-gray-200 dark:border-slate-700">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 text-sm font-semibold text-gray-900 dark:text-white">{faq.q}<Icon name="tabler:chevron-down" class="h-4 w-4 flex-shrink-0 transition-transform group-open:rotate-180"/></summary>
            <div class="px-6 pb-4 text-sm text-muted">{faq.a}</div>
          </details>
        ))}
      </div>
      <div class="mt-10 rounded-xl bg-teal-50 p-6 text-center dark:bg-teal-900/20">
        <p class="font-semibold text-teal-800 dark:text-teal-200">Ready to get started?</p>
        <div class="mt-3 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
          <a href="/all-products" class="inline-flex items-center gap-2 rounded-xl bg-teal-600 px-6 py-3 text-sm font-semibold text-white hover:bg-teal-700">Browse Products</a>
          <a href="/inquiry" class="inline-flex items-center gap-2 rounded-xl border border-teal-300 px-6 py-3 text-sm font-semibold text-teal-700 hover:bg-teal-100 dark:border-teal-700 dark:text-teal-400 dark:hover:bg-teal-900/20"><Icon name="tabler:mail" class="h-4 w-4"/> Contact Us</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
