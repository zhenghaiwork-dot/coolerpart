---
import Layout from '~/layouts/InquiryLayout.astro';
import { Icon } from 'astro-icon/components';
import { systemsData } from '~/data/systems';
import { getAllProducts } from '~/data/product-helpers';
import ProductCard from '~/components/inquiry/ProductCard.astro';

const productsData = await getAllProducts();

// Group products by system, preserving system order
const systemGroups = systemsData
  .map((sys) => ({
    system: sys,
    products: productsData.filter((p) => p.systemSlug === sys.slug),
  }))
  .filter((g) => g.products.length > 0);

const totalParts = productsData.length;
const totalSystems = systemGroups.length;
const totalTypes = new Set(productsData.map((p) => p.productTypeSlug)).size;
---

<Layout metadata={{ title: 'All Products — Evaporative Cooler Replacement Parts Catalog', ignoreTitleTemplate: true }}>
  <!-- ═══════════════════════════════════════════════
       HERO — compact, light, with search
  ═══════════════════════════════════════════════ -->
  <section class="relative overflow-hidden border-b border-gray-200 bg-white dark:border-slate-800 dark:bg-slate-900">
    <div class="absolute inset-0 tech-grid opacity-40"></div>
    <div class="relative mx-auto max-w-7xl px-6 py-12 lg:py-16">
      <div class="max-w-2xl">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-teal-600 dark:text-teal-400">
          Complete Parts Catalog
        </p>
        <h1
          class="mt-3 text-4xl font-bold leading-[1.1] text-gray-900 dark:text-white sm:text-5xl text-balance"
          style="font-family: 'Space Grotesk Variable', sans-serif; letter-spacing: -0.03em;"
        >
          All Replacement Parts
        </h1>
        <p class="mt-4 text-lg leading-relaxed text-gray-600 dark:text-gray-300">
          Browse the full catalog of evaporative cooler components. Filter by system or search by name, spec, or keyword.
        </p>
      </div>

      <!-- Search bar -->
      <div class="mt-8 max-w-2xl">
        <label for="product-search" class="sr-only">Search products by name, spec, or keyword</label>
        <div class="relative">
          <span class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-4">
            <Icon name="tabler:search" class="h-5 w-5 text-gray-400 dark:text-gray-500" />
          </span>
          <input
            id="product-search"
            type="text"
            placeholder="Search by name, spec, or keyword — e.g. 110V, pump, capacitor, B3 mount..."
            aria-label="Search products by name, spec, or keyword"
            class="w-full rounded-xl border border-gray-300 bg-white py-3.5 pl-12 pr-12 text-sm text-gray-900 shadow-sm transition-all placeholder:text-gray-400 focus:border-teal-500 focus:outline-none focus:ring-2 focus:ring-teal-500/20 dark:border-slate-600 dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-500 dark:focus:border-teal-400"
          />
          <button
            id="search-clear"
            type="button"
            aria-label="Clear search"
            class="absolute inset-y-0 right-0 hidden items-center pr-4 text-gray-400 hover:text-gray-600 dark:hover:text-gray-200"
          >
            <Icon name="tabler:x" class="h-5 w-5" />
          </button>
        </div>
      </div>

      <!-- Stats bar -->
      <div class="mt-6 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-gray-500 dark:text-gray-400">
        <span><span class="font-semibold text-gray-900 dark:text-white tabular-nums">{totalParts}</span> parts</span>
        <span class="h-3 w-px bg-gray-300 dark:bg-slate-700"></span>
        <span><span class="font-semibold text-gray-900 dark:text-white tabular-nums">{totalTypes}</span> product types</span>
        <span class="h-3 w-px bg-gray-300 dark:bg-slate-700"></span>
        <span><span class="font-semibold text-gray-900 dark:text-white tabular-nums">{totalSystems}</span> systems</span>
        <span class="h-3 w-px bg-gray-300 dark:bg-slate-700"></span>
        <span>Direct inquiry — no checkout</span>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       PRODUCT CATALOG — grouped by system
  ═══════════════════════════════════════════════ -->
  <section class="bg-gray-50 dark:bg-slate-800/30">
    <div class="mx-auto max-w-7xl px-6 py-12 lg:py-16">
      <!-- Search result counter -->
      <div id="search-meta" class="mb-6 hidden">
        <div class="flex items-center justify-between rounded-lg border border-gray-200 bg-white px-4 py-2.5 dark:border-slate-700 dark:bg-slate-900">
          <p id="search-results-count" class="text-sm text-gray-600 dark:text-gray-300"></p>
          <button
            id="search-reset"
            type="button"
            class="text-xs font-semibold text-teal-600 hover:text-teal-700 dark:text-teal-400 dark:hover:text-teal-300"
          >
            Clear search
          </button>
        </div>
      </div>

      <!-- Catalog wrapper (for event delegation) -->
      <div id="catalog-wrapper">
        <!-- System groups -->
        {systemGroups.map(({ system, products }) => (
          <div data-system-group class="mb-10 last:mb-0">
            <!-- System group header -->
            <div class="mb-4 flex items-center gap-3">
              <span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg bg-teal-50 text-teal-600 dark:bg-teal-500/10 dark:text-teal-400">
                <Icon name={system.icon} class="h-4 w-4" />
              </span>
              <div class="flex-1 min-w-0">
                <h2
                  class="text-lg font-bold text-gray-900 dark:text-white"
                  style="font-family: 'Space Grotesk Variable', sans-serif; letter-spacing: -0.02em;"
                >
                  {system.name}
                </h2>
              </div>
              <a
                href={`/${system.slug}`}
                class="flex-shrink-0 text-xs font-semibold text-teal-600 hover:text-teal-700 dark:text-teal-400 dark:hover:text-teal-300"
              >
                View system →
              </a>
              <span class="flex-shrink-0 tech-label text-gray-400 dark:text-gray-500">
                <span data-count class="tabular-nums">{products.length}</span> parts
              </span>
            </div>

            <!-- Product grid -->
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
              {products.map((product) => (
                <ProductCard product={product} />
              ))}
            </div>
          </div>
        ))}

        <!-- Empty state (hidden by default) -->
        <div id="no-results" class="hidden py-16 text-center">
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-gray-100 dark:bg-slate-800">
            <Icon name="tabler:search-off" class="h-8 w-8 text-gray-400 dark:text-gray-500" />
          </div>
          <h3
            class="mt-4 text-xl font-bold text-gray-900 dark:text-white"
            style="font-family: 'Space Grotesk Variable', sans-serif; letter-spacing: -0.02em;"
          >
            No parts found
          </h3>
          <p class="mx-auto mt-2 max-w-md text-sm text-gray-500 dark:text-gray-400 leading-relaxed">
            Try a different keyword, or skip browsing and send your requirements directly.
          </p>
          <div class="mt-6 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
            <button
              id="reset-search-btn"
              type="button"
              class="inline-flex items-center justify-center gap-2 rounded-lg border border-gray-300 bg-white px-5 py-2.5 text-sm font-semibold text-gray-900 transition-all hover:border-teal-500 hover:text-teal-600 dark:border-slate-600 dark:bg-slate-800 dark:text-white dark:hover:border-teal-400 dark:hover:text-teal-400"
            >
              <Icon name="tabler:rotate" class="h-4 w-4" />
              Reset search
            </button>
            <a
              href="/inquiry"
              class="inline-flex items-center justify-center gap-2 rounded-lg bg-teal-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition-all hover:bg-teal-700 hover:shadow-md"
            >
              <Icon name="tabler:mail" class="h-4 w-4" />
              Send RFQ directly
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  // ── Search functionality ──
  const input = document.getElementById('product-search') as HTMLInputElement | null;
  const clearBtn = document.getElementById('search-clear');
  const searchMeta = document.getElementById('search-meta');
  const countEl = document.getElementById('search-results-count');
  const resetBtn = document.getElementById('search-reset');
  const resetBtn2 = document.getElementById('reset-search-btn');
  const wrapper = document.getElementById('catalog-wrapper');
  const noResults = document.getElementById('no-results');

  if (!input || !wrapper) {
    // Silently skip if elements missing
  } else {
    const cards = wrapper.querySelectorAll<HTMLElement>('.product-card');
    const groups = wrapper.querySelectorAll<HTMLElement>('[data-system-group]');
    const totalCards = cards.length;

    function performSearch() {
      const q = input!.value.toLowerCase().trim();

      // Toggle clear button
      if (clearBtn) clearBtn.classList.toggle('hidden', !q);
      if (clearBtn) clearBtn.classList.toggle('flex', !!q);

      if (!q) {
        // Reset: show everything
        cards.forEach((c) => (c.style.display = ''));
        groups.forEach((g) => (g.style.display = ''));
        if (searchMeta) searchMeta.classList.add('hidden');
        if (noResults) noResults.classList.add('hidden');
        return;
      }

      let visible = 0;
      groups.forEach((group) => {
        const groupCards = group.querySelectorAll<HTMLElement>('.product-card');
        let groupVisible = 0;
        groupCards.forEach((card) => {
          const text = card.textContent?.toLowerCase() || '';
          const match = text.includes(q);
          card.style.display = match ? '' : 'none';
          if (match) {
            groupVisible++;
            visible++;
          }
        });
        group.style.display = groupVisible > 0 ? '' : 'none';
      });

      // Update count
      if (countEl) {
        countEl.innerHTML = `Showing <span class="font-semibold text-gray-900 dark:text-white">${visible}</span> of <span class="font-semibold text-gray-900 dark:text-white">${totalCards}</span> parts matching "<span class="font-semibold text-gray-900 dark:text-white">${q}</span>"`;
      }
      if (searchMeta) searchMeta.classList.toggle('hidden', visible === 0);
      if (noResults) noResults.classList.toggle('hidden', visible > 0);
    }

    input.addEventListener('input', performSearch);

    // Clear search button (in input)
    if (clearBtn) {
      clearBtn.addEventListener('click', () => {
        input.value = '';
        performSearch();
        input.focus();
      });
    }

    // Reset search button (in search meta bar)
    if (resetBtn) {
      resetBtn.addEventListener('click', () => {
        input.value = '';
        performSearch();
        input.focus();
      });
    }

    // Reset search button (in empty state)
    if (resetBtn2) {
      resetBtn2.addEventListener('click', () => {
        input.value = '';
        performSearch();
        input.focus();
      });
    }

    // Keyboard: Escape clears search
    input.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape') {
        input.value = '';
        performSearch();
        input.blur();
      }
    });
  }
</script>
